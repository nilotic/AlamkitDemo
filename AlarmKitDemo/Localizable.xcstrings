        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "알람 권한이 거부되었어요. 설정에서 권한을 켜야 알람을 사용할 수 있어요."
          }
        }
      }
    },
    "alarm.error.invalidDate" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Check the alarm time. You need to select a valid time after now."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "알람 시간을 확인해 주세요. 현재 시점 이후의 유효한 시간을 선택해야 해요."
          }
        }
      }
    },
    "alarm.error.notFound" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
